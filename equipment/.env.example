# Trigger.dev secret key — from dashboard.trigger.dev → API Keys
TRIGGER_SECRET_KEY=tr_dev_your_key_here

# Trigger.dev project reference — from Project Settings
TRIGGER_PROJECT_REF=proj_your_project_ref_here

# Firecrawl API key — from firecrawl.dev dashboard
FIRECRAWL_API_KEY=fc-your_key_here

# Supabase — from supabase.com → Project Settings → API
# Project URL (Settings → API → Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — safe for client-side use, subject to RLS
# (Settings → API → Project API keys → anon public)
SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — bypasses RLS, server-side only, keep secret
# (Settings → API → Project API keys → service_role)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Direct Postgres connection string — used for migrations / raw SQL
# (Settings → Database → Connection string → URI — use Transaction mode for serverless)
SUPABASE_DB_URL=postgresql://postgres:[password]@db.your-project-ref.supabase.co:5432/postgres

# Anthropic API key — from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
