# Trigger.dev secret key — from dashboard.trigger.dev → API Keys
TRIGGER_SECRET_KEY=tr_dev_your_key_here

# Trigger.dev project reference — from Project Settings
TRIGGER_PROJECT_REF=proj_your_project_ref_here

# Firecrawl API key — from firecrawl.dev dashboard
FIRECRAWL_API_KEY=fc-your_key_here

# Supabase — from supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
