# Trigger.dev — server-side only (used in API route to trigger jobs)
TRIGGER_SECRET_KEY=tr_dev_your_key_here

# Trigger.dev — client-side safe (used to poll run status)
NEXT_PUBLIC_TRIGGER_PUBLIC_API_KEY=pk_your_public_key_here

# Supabase — client-side safe (subject to RLS), also used for Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase — server-side only (bypasses RLS, used by equipment/ job to write leads)
# Get from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
