# Trigger.dev — server-side only (used in API route to trigger jobs)
TRIGGER_SECRET_KEY=tr_dev_your_key_here

# Trigger.dev — client-side safe (used in browser to poll run status)
NEXT_PUBLIC_TRIGGER_PUBLIC_API_KEY=pk_dev_your_public_key_here

# Supabase — client-side safe
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
