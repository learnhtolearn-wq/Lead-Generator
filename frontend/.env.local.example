# Trigger.dev — server-side only (used in API route to trigger jobs)
TRIGGER_SECRET_KEY=tr_dev_your_key_here

# Supabase — client-side safe
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Password required to access the app (set any string you choose)
APP_PASSWORD=your_access_password_here
